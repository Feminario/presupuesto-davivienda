import { useState } from "react";

const TALLY_FORM_ID = "Pdbax1";

const LOGO_FEM  = "data:image/png;base64,";
const LOGO_DAVI = "data:image/png;base64,";

const C = {
  plum: "#6B4B8A", teal: "#4A7C7E", peach: "#E8A87C",
  lilac: "#CEA2DD", dark: "#3C2260", davi: "#C8102E",
};

const PAISES = [
  { code: "+57",  flag: "🇨🇴", name: "Colombia"    },
  { code: "+1",   flag: "🇺🇸", name: "EE.UU."      },
  { code: "+52",  flag: "🇲🇽", name: "México"      },
  { code: "+34",  flag: "🇪🇸", name: "España"      },
  { code: "+54",  flag: "🇦🇷", name: "Argentina"   },
  { code: "+56",  flag: "🇨🇱", name: "Chile"       },
  { code: "+51",  flag: "🇵🇪", name: "Perú"        },
  { code: "+593", flag: "🇪🇨", name: "Ecuador"     },
  { code: "+58",  flag: "🇻🇪", name: "Venezuela"   },
  { code: "+55",  flag: "🇧🇷", name: "Brasil"      },
];

const fmt = (n) =>
  new Intl.NumberFormat("es-CO", { style: "currency", currency: "COP", maximumFractionDigits: 0 }).format(Math.round(n || 0));

const CATS = {
  necesidades: [
    { id: "vivienda",   label: "Arriendo o cuota de tu casa",        e: "🏠" },
    { id: "mercado",    label: "Mercado y comida en casa",            e: "🛒" },
    { id: "transporte", label: "Transporte (bus, Uber, gasolina)",    e: "🚌" },
    { id: "salud",      label: "Salud, medicina y seguros",           e: "💊" },
    { id: "servicios",  label: "Servicios públicos e internet",       e: "💡" },
  ],
  deseos: [
    { id: "restaurantes", label: "Restaurantes y domicilios",          e: "🍕" },
    { id: "entrete",      label: "Salidas, cine y entretenimiento",     e: "🎉" },
    { id: "ropa",         label: "Ropa, belleza y cuidado personal",    e: "👗" },
    { id: "subs",         label: "Netflix, Spotify y otras apps",       e: "📱" },
    { id: "otros",        label: "Otros gustos personales",             e: "✨" },
  ],
  ahorro: [
    { id: "ahorro_cuenta", label: "Ahorro en cuenta o CDT",            e: "🏦" },
    { id: "inversiones",   label: "Inversiones (acciones, fondos)",     e: "📈" },
    { id: "emergencia",    label: "Fondo de emergencias",               e: "🛡️" },
    { id: "deudas",        label: "Pago de deudas o créditos",          e: "💳" },
  ],
};

function Bar({ label, pct, ideal, sub }) {
  const over = pct > ideal;
  const barW = Math.min(Math.round(pct), 120);
  return (
    <div style={{ marginBottom: 18 }}>
      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 5, alignItems: "baseline" }}>
        <span style={{ fontSize: 13, color: "#d4c8ee", fontWeight: 600 }}>{label}</span>
        <div style={{ display: "flex", gap: 10, alignItems: "center" }}>
          <span style={{ fontSize: 11, color: "#5a4d6e" }}>meta {ideal}%</span>
          <span style={{ fontSize: 15, fontWeight: 700, color: over ? C.peach : C.teal }}>{Math.round(pct)}%</span>
        </div>
      </div>
      <div style={{ height: 8, borderRadius: 4, background: "rgba(255,255,255,0.07)", position: "relative" }}>
        <div style={{ height: "100%", borderRadius: 4, width: `${barW}%`, background: over ? C.peach : C.teal, transition: "width .6s ease" }} />
        <div style={{ position: "absolute", top: -3, left: `${ideal}%`, width: 2, height: 14, background: "rgba(255,255,255,0.25)", borderRadius: 1 }} />
      </div>
      {sub && <p style={{ margin: "5px 0 0", fontSize: 11, color: "#5a4d6e" }}>{sub}</p>}
    </div>
  );
}

function CatRow({ item, value, onChange }) {
  return (
    <div style={{ display: "flex", alignItems: "center", gap: 10, background: "rgba(255,255,255,0.04)", borderRadius: 10, padding: "9px 13px", marginBottom: 7, border: "1px solid rgba(107,75,138,0.13)" }}>
      <span style={{ fontSize: 17 }}>{item.e}</span>
      <span style={{ flex: 1, fontSize: 12, color: "#b8a8d8", lineHeight: 1.3 }}>{item.label}</span>
      <span style={{ fontSize: 12, color: "#5a4d6e" }}>$</span>
      <input type="number" min="0" value={value || ""} onChange={e => onChange(parseFloat(e.target.value) || 0)} placeholder="0"
        style={{ width: 88, background: "transparent", border: "none", outline: "none", color: C.peach, fontFamily: "Montserrat,sans-serif", fontSize: 13, fontWeight: 700, textAlign: "right" }} />
    </div>
  );
}

function Header({ step }) {
  return (
    <div style={{ background: "rgba(107,75,138,0.13)", borderBottom: "1px solid rgba(107,75,138,0.18)", padding: "18px 22px" }}>
      <div style={{ display: "flex", justifyContent: "center", alignItems: "center", gap: 28, flexWrap: "wrap", marginBottom: 14 }}>
        <img src={LOGO_FEM} alt="Feminario" style={{ height: 34, objectFit: "contain", mixBlendMode: "screen" }} />
        <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 3 }}>
          <span style={{ fontSize: 9, color: "#5a4d6e", textTransform: "uppercase", letterSpacing: 1 }}>En alianza con</span>
          <img src={LOGO_DAVI} alt="Davivienda" style={{ height: 28, objectFit: "contain", mixBlendMode: "screen" }} />
        </div>
      </div>
      <div style={{ textAlign: "center" }}>
        <h1 style={{ margin: "0 0 3px", fontSize: "clamp(17px,4vw,26px)", fontWeight: 700, color: "#f5f0ff" }}>Mi Presupuesto Inteligente</h1>
        <p style={{ margin: "0 0 14px", fontSize: 12, color: "#7a6d90", fontStyle: "italic" }}>
          El lugar seguro donde las mujeres redefinimos las reglas de la autonomía económica
        </p>
        <div style={{ display: "flex", justifyContent: "center", alignItems: "center", gap: 7 }}>
          {["Registro", "Gastos", "Análisis"].map((lbl, i) => {
            const s = i + 1, active = step === s, done = step > s;
            return (
              <div key={s} style={{ display: "flex", alignItems: "center", gap: 6 }}>
                <div style={{ display: "flex", alignItems: "center", gap: 5 }}>
                  <div style={{ width: 22, height: 22, borderRadius: "50%", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 10, fontWeight: 700, transition: "all .3s", background: done ? C.teal : active ? C.plum : "rgba(255,255,255,0.08)", color: done || active ? "#fff" : "#5a4d6e" }}>
                    {done ? "✓" : s}
                  </div>
                  <span style={{ fontSize: 10, color: active ? C.lilac : done ? C.teal : "#5a4d6e" }}>{lbl}</span>
                </div>
                {i < 2 && <div style={{ width: 18, height: 1, background: done ? C.teal : "rgba(255,255,255,0.08)" }} />}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  );
}

export default function Presupuesto() {
  const [step, setStep] = useState(1);
  const [reg, setReg] = useState({ nombre: "", apellido: "", email: "", indicativo: "+57", celular: "" });
  const [errors, setErrors] = useState({});
  const [submitting, setSubmitting] = useState(false);
  const [income, setIncome] = useState(0);
  const [exp, setExp] = useState({});

  const setF = (k, v) => setReg(p => ({ ...p, [k]: v }));
  const setE = (id, v) => setExp(p => ({ ...p, [id]: v }));
  const sum = (cat) => CATS[cat].reduce((s, c) => s + (exp[c.id] || 0), 0);

  const validate = () => {
    const e = {};
    if (!reg.nombre.trim()) e.nombre = 1;
    if (!reg.apellido.trim()) e.apellido = 1;
    if (!reg.email.includes("@") || !reg.email.includes(".")) e.email = 1;
    if (reg.celular.replace(/\D/g, "").length < 6) e.celular = 1;
    setErrors(e);
    return !Object.keys(e).length;
  };

  const submitToTally = (data) => {
    try {
      const ifr = document.createElement("iframe");
      ifr.name = "tally-ifr"; ifr.style.display = "none";
      document.body.appendChild(ifr);
      const form = document.createElement("form");
      form.method = "POST"; form.action = `https://tally.so/r/${TALLY_FORM_ID}`; form.target = "tally-ifr";
      Object.entries(data).forEach(([k, v]) => {
        const inp = document.createElement("input");
        inp.type = "hidden"; inp.name = k; inp.value = v;
        form.appendChild(inp);
      });
      document.body.appendChild(form);
      form.submit();
      setTimeout(() => { document.body.removeChild(form); document.body.removeChild(ifr); }, 3000);
    } catch (_) {}
  };

  const handleRegistro = () => {
    if (!validate()) return;
    setSubmitting(true);
    submitToTally({
      nombre: reg.nombre,
      apellido: reg.apellido,
      email: reg.email,
      celular: `${reg.indicativo} ${reg.celular}`,
    });
    setTimeout(() => { setSubmitting(false); setStep(2); }, 700);
  };

  const inc = income || 0;
  const nec = sum("necesidades"), des = sum("deseos"), aho = sum("ahorro");
  const necPct = inc > 0 ? (nec / inc) * 100 : 0;
  const desPct = inc > 0 ? (des / inc) * 100 : 0;
  const ahoPct = inc > 0 ? (aho / inc) * 100 : 0;

  const getPath = () => {
    if (ahoPct < 5)  return { label: "80/20",       color: C.peach,  emoji: "🌱", desc: `Empecemos por crear el hábito. Tu primera meta es separar el 20% antes de gastar — eso son ${fmt(inc * 0.20)} al mes. Automatiza esa transferencia el día que te paguen. El 80% restante es para todo lo demás.` };
    if (ahoPct < 15) return { label: "70/30",       color: C.lilac,  emoji: "📈", desc: `Vas muy bien. El siguiente escalón es llegar al 30% entre ahorro e inversión. Eso significa separar ${fmt((inc * 0.30) - aho)} adicionales al mes, reduciendo gradualmente los deseos.` };
    if (ahoPct < 20) return { label: "75/25",       color: "#9bd4c5", emoji: "💪", desc: `Casi llegas. Solo te faltan ${fmt((inc * 0.20) - aho)} al mes para estar en el objetivo del 20%. Un ajuste pequeño en tus deseos puede cerrar esa brecha este mismo mes.` };
    return              { label: "50/30/20 ✨",   color: C.teal,   emoji: "🎉", desc: "¡Estás en el objetivo! Estás ahorrando e invirtiendo lo que la regla recomienda. Ahora el reto es que ese dinero trabaje: ponlo en ETFs, acciones o fondos que generen retornos a largo plazo." };
  };

  const getTips = () => {
    const tips = [];
    if (necPct > 55) tips.push({ e: "🏠", txt: "Tus necesidades básicas superan el 50%. Es lo más difícil de recortar, pero vale revisar: ¿puedes consolidar servicios? ¿Hay alternativas de transporte más económicas? ¿Tu arriendo tiene margen de negociación?" });
    if (desPct > 30) {
      const top = CATS.deseos.reduce((m, c) => (exp[c.id] || 0) > (exp[m.id] || 0) ? c : m, CATS.deseos[0]);
      if (exp[top.id] > 0) tips.push({ e: top.e, txt: `Tu mayor gasto en deseos es "${top.label}" con ${fmt(exp[top.id])} al mes. No tienes que eliminarlo — solo ponle un tope fijo. Ese simple control puede liberar ${fmt(Math.max(0, des - inc * 0.30))} al mes.` });
    }
    if (ahoPct < 1) tips.push({ e: "💡", txt: "Este mes no separaste nada para ti misma. Empieza con el 5% — lo que sea. Una transferencia automática el día que te paguen cambia el hábito sin que lo notes." });
    if (tips.length === 0) tips.push({ e: "✅", txt: "¡Tu presupuesto tiene buena estructura! El siguiente paso es que tu ahorro trabaje: invierte en ETFs, fondos de inversión o acciones que generen retornos reales a largo plazo." });
    return tips;
  };

  const path = getPath();
  const tips = getTips();
  const topNec = CATS.necesidades.reduce((m, c) => (exp[c.id] || 0) > (exp[m.id] || 0) ? c : m, CATS.necesidades[0]);
  const topDes = CATS.deseos.reduce((m, c) => (exp[c.id] || 0) > (exp[m.id] || 0) ? c : m, CATS.deseos[0]);

  const inpBase = { background: "rgba(255,255,255,0.05)", fontFamily: "Montserrat,sans-serif", fontSize: 14, outline: "none", color: "#f5f0ff" };
  const card = (border = "rgba(107,75,138,0.18)") => ({ background: "rgba(255,255,255,0.03)", border: `1px solid ${border}`, borderRadius: 14, padding: 20, marginBottom: 16 });

  return (
    <div style={{ background: "linear-gradient(160deg,#0d0719 0%,#140a2b 60%,#0a1a1a 100%)", minHeight: "100vh", fontFamily: "Montserrat,sans-serif", color: "#f5f0ff" }}>
      <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />
      <Header step={step} />

      <div style={{ maxWidth: 680, margin: "0 auto", padding: "26px 17px 40px" }}>

        {step === 1 && (
          <div>
            <h2 style={{ margin: "0 0 7px", fontSize: 21, fontWeight: 700 }}>Primero, cuéntanos quién eres 👋</h2>
            <p style={{ margin: "0 0 22px", color: "#a89bc2", fontSize: 13, lineHeight: 1.7 }}>
              Esta información nos ayuda a acompañarte mejor y a mantenerte conectada a la comunidad Feminario.
            </p>

            {[
              { k: "nombre",   l: "Nombre *",            p: "Tu nombre",        t: "text"  },
              { k: "apellido", l: "Apellido *",           p: "Tu apellido",      t: "text"  },
              { k: "email",    l: "Correo electrónico *", p: "hola@ejemplo.com", t: "email" },
            ].map(({ k, l, p, t }) => (
              <div key={k} style={{ marginBottom: 13 }}>
                <label style={{ display: "block", fontSize: 10, fontWeight: 700, color: errors[k] ? C.peach : C.lilac, marginBottom: 5, textTransform: "uppercase", letterSpacing: 1 }}>{l}</label>
                <input type={t} value={reg[k]} onChange={e => setF(k, e.target.value)}
                  placeholder={p}
                  style={{ ...inpBase, width: "100%", padding: "12px 15px", borderRadius: 10, boxSizing: "border-box", border: `1px solid ${errors[k] ? C.peach : "rgba(107,75,138,0.28)"}` }} />
                {errors[k] && <p style={{ margin: "3px 0 0", fontSize: 10, color: C.peach }}>{k === "email" ? "Ingresa un correo válido" : "Este campo es obligatorio"}</p>}
              </div>
            ))}

            {/* Celular con indicativo */}
            <div style={{ marginBottom: 13 }}>
              <label style={{ display: "block", fontSize: 10, fontWeight: 700, color: errors.celular ? C.peach : C.lilac, marginBottom: 5, textTransform: "uppercase", letterSpacing: 1 }}>Celular *</label>
              <div style={{ display: "flex", gap: 8 }}>
                <select value={reg.indicativo} onChange={e => setF("indicativo", e.target.value)}
                  style={{ ...inpBase, padding: "12px 10px", borderRadius: 10, border: "1px solid rgba(107,75,138,0.28)", flexShrink: 0, width: 140, cursor: "pointer" }}>
                  {PAISES.map(p => (
                    <option key={p.code + p.name} value={p.code} style={{ background: "#140a2b" }}>
                      {p.flag} {p.code} {p.name}
                    </option>
                  ))}
                </select>
                <input type="tel" value={reg.celular} onChange={e => setF("celular", e.target.value)}
                  placeholder="300 123 4567"
                  style={{ ...inpBase, flex: 1, padding: "12px 15px", borderRadius: 10, border: `1px solid ${errors.celular ? C.peach : "rgba(107,75,138,0.28)"}` }} />
              </div>
              {errors.celular && <p style={{ margin: "3px 0 0", fontSize: 10, color: C.peach }}>Ingresa un número de celular válido</p>}
            </div>

            <button onClick={handleRegistro} disabled={submitting}
              style={{ width: "100%", padding: 15, borderRadius: 12, background: submitting ? "rgba(107,75,138,0.4)" : C.plum, border: "none", color: "#fff", fontFamily: "Montserrat,sans-serif", fontSize: 14, fontWeight: 700, cursor: submitting ? "default" : "pointer", marginTop: 6, transition: "background .2s" }}>
              {submitting ? "Guardando..." : "Continuar → Analizar mi presupuesto"}
            </button>
            <p style={{ textAlign: "center", fontSize: 10, color: "#5a4d6e", marginTop: 10 }}>🔒 Tus datos están seguros. Los usamos solo para Feminario.</p>
          </div>
        )}

        {step === 2 && (
          <div>
            <h2 style={{ margin: "0 0 7px", fontSize: 21, fontWeight: 700 }}>¿En qué se va tu plata? 💸</h2>
            <p style={{ margin: "0 0 22px", color: "#a89bc2", fontSize: 13, lineHeight: 1.7 }}>No tienes que ser exacta al 100%. Pon tus montos aproximados — lo importante es ver el panorama completo.</p>

            <div style={{ ...card(`${C.plum}38`), background: "rgba(107,75,138,0.13)" }}>
              <p style={{ margin: "0 0 5px", fontSize: 10, fontWeight: 700, color: C.lilac, textTransform: "uppercase", letterSpacing: 1 }}>💰 ¿Cuánto recibes al mes en total? *</p>
              <p style={{ margin: "0 0 11px", fontSize: 12, color: "#7a6d90" }}>Suma sueldo, freelance, arriendos que recibes — todo lo que entra.</p>
              <div style={{ display: "flex", alignItems: "center", gap: 8, background: "rgba(0,0,0,0.2)", borderRadius: 10, padding: "11px 15px" }}>
                <span style={{ color: "#5a4d6e", fontSize: 16 }}>$</span>
                <input type="number" min="0" value={income || ""} onChange={e => setIncome(parseFloat(e.target.value) || 0)} placeholder="0"
                  style={{ flex: 1, background: "transparent", border: "none", outline: "none", color: C.peach, fontFamily: "Montserrat,sans-serif", fontSize: 22, fontWeight: 700 }} />
              </div>
              {inc > 0 && <p style={{ margin: "7px 0 0", fontSize: 12, color: C.teal }}>= {fmt(inc)} al mes</p>}
            </div>

            {[
              { key: "necesidades", title: "🏡 Necesidades", sub: "Lo que no puedes eliminar: vivienda, comida, transporte, salud.", color: C.teal,  bg: "rgba(74,124,126,0.07)",  border: "rgba(74,124,126,0.2)",  target: "50%" },
              { key: "deseos",      title: "🎀 Deseos",      sub: "Lo que disfrutas pero podrías ajustar si fuera necesario.",    color: C.lilac, bg: "rgba(206,162,221,0.06)", border: "rgba(206,162,221,0.2)", target: "30%" },
              { key: "ahorro",      title: "🌱 Ahorro e Inversión", sub: "Todo lo que estás separando para ti misma y tu futuro.", color: C.peach, bg: "rgba(232,168,124,0.06)", border: "rgba(232,168,124,0.2)", target: "20%" },
            ].map(({ key, title, sub, color, bg, border, target }) => (
              <div key={key} style={{ background: bg, border: `1px solid ${border}`, borderRadius: 14, padding: 18, marginBottom: 13 }}>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline", marginBottom: 3 }}>
                  <p style={{ margin: 0, fontSize: 11, fontWeight: 700, color, textTransform: "uppercase", letterSpacing: 1 }}>{title}</p>
                  <span style={{ fontSize: 10, color: "#5a4d6e" }}>meta: {target}</span>
                </div>
                <p style={{ margin: "0 0 13px", fontSize: 12, color: "#7a6d90" }}>{sub}</p>
                {CATS[key].map(item => <CatRow key={item.id} item={item} value={exp[item.id]} onChange={v => setE(item.id, v)} />)}
                {inc > 0 && (
                  <p style={{ margin: "9px 0 0", fontSize: 11, color, textAlign: "right" }}>
                    Subtotal: <strong>{fmt(sum(key))}</strong> <span style={{ color: "#5a4d6e" }}>({Math.round((sum(key)/inc)*100)}%)</span>
                  </p>
                )}
              </div>
            ))}

            <button onClick={() => { if (!income) { alert("Ingresa primero tus ingresos mensuales 💛"); return; } setStep(3); }}
              style={{ width: "100%", padding: 15, borderRadius: 12, background: C.plum, border: "none", color: "#fff", fontFamily: "Montserrat,sans-serif", fontSize: 14, fontWeight: 700, cursor: "pointer" }}>
              Ver mi análisis →
            </button>
          </div>
        )}

        {step === 3 && (
          <div>
            <h2 style={{ margin: "0 0 5px", fontSize: 21, fontWeight: 700 }}>{path.emoji} Así está tu presupuesto</h2>
            <p style={{ margin: "0 0 22px", color: "#a89bc2", fontSize: 13 }}>
              Hola, <strong style={{ color: C.lilac }}>{reg.nombre}</strong>. Aquí está el resultado de lo que nos contaste.
            </p>

            <div style={{ display: "flex", gap: 9, flexWrap: "wrap", marginBottom: 17 }}>
              {[
                { l: "Ingresos",           v: fmt(inc),          color: C.teal  },
                { l: "Gastos registrados", v: fmt(nec+des+aho),  color: C.peach },
                { l: "Ahorro mensual",     v: fmt(aho),          color: C.lilac },
              ].map(({ l, v, color }) => (
                <div key={l} style={{ flex: "1 1 130px", background: "rgba(0,0,0,0.22)", borderRadius: 12, padding: 13, textAlign: "center", border: `1px solid ${color}22` }}>
                  <p style={{ margin: "0 0 3px", fontSize: 10, color: "#5a4d6e", textTransform: "uppercase", letterSpacing: 1 }}>{l}</p>
                  <p style={{ margin: 0, fontSize: 14, fontWeight: 700, color }}>{v}</p>
                </div>
              ))}
            </div>

            <div style={card()}>
              <p style={{ margin: "0 0 16px", fontSize: 13, fontWeight: 700, color: "#f5f0ff" }}>La regla 50/30/20 — ¿cómo estás?</p>
              <Bar label="🏡 Necesidades"        pct={necPct} ideal={50} sub={`${fmt(nec)} · meta ${fmt(inc*0.5)}`} />
              <Bar label="🎀 Deseos"             pct={desPct} ideal={30} sub={`${fmt(des)} · meta ${fmt(inc*0.3)}`} />
              <Bar label="🌱 Ahorro e inversión" pct={ahoPct} ideal={20} sub={`${fmt(aho)} · meta ${fmt(inc*0.2)}`} />
            </div>

            <div style={{ ...card(`${path.color}38`), background: `${path.color}12` }}>
              <p style={{ margin: "0 0 3px", fontSize: 10, color: path.color, textTransform: "uppercase", letterSpacing: 2, fontWeight: 700 }}>Tu regla recomendada ahora</p>
              <p style={{ margin: "0 0 11px", fontSize: 26, fontWeight: 700, color: path.color }}>Regla {path.label}</p>
              <p style={{ margin: 0, fontSize: 13, color: "#c4b8e0", lineHeight: 1.75 }}>{path.desc}</p>
            </div>

            <div style={card("rgba(74,124,126,0.18)")}>
              <p style={{ margin: "0 0 13px", fontSize: 13, fontWeight: 700, color: C.teal }}>💡 Lo que te recomendamos revisar</p>
              {tips.map((t, i) => (
                <div key={i} style={{ display: "flex", gap: 10, marginBottom: 11, paddingBottom: 11, borderBottom: i < tips.length-1 ? "1px solid rgba(255,255,255,0.05)" : "none" }}>
                  <span style={{ fontSize: 17, flexShrink: 0, marginTop: 2 }}>{t.e}</span>
                  <p style={{ margin: 0, fontSize: 13, color: "#b8a8d8", lineHeight: 1.75 }}>{t.txt}</p>
                </div>
              ))}
            </div>

            <div style={{ display: "flex", gap: 9, flexWrap: "wrap", marginBottom: 16 }}>
              {[
                { l: "Mayor necesidad", item: topNec, color: C.teal  },
                { l: "Mayor deseo",     item: topDes, color: C.lilac },
              ].map(({ l, item, color }) => (
                <div key={l} style={{ flex: "1 1 170px", background: "rgba(0,0,0,0.2)", borderRadius: 12, padding: 13, border: `1px solid ${color}18` }}>
                  <p style={{ margin: "0 0 3px", fontSize: 10, color: "#5a4d6e", textTransform: "uppercase", letterSpacing: 1 }}>{l}</p>
                  <p style={{ margin: "0 0 2px", fontSize: 11, color: "#c4b8e0" }}>{item.e} {item.label}</p>
                  <p style={{ margin: 0, fontSize: 16, fontWeight: 700, color }}>{fmt(exp[item.id] || 0)}</p>
                </div>
              ))}
            </div>

            <div style={{ textAlign: "center", padding: 22, background: "rgba(107,75,138,0.1)", borderRadius: 14, border: "1px solid rgba(107,75,138,0.2)", marginBottom: 18 }}>
              <p style={{ margin: "0 0 5px", fontSize: 16, fontWeight: 700, color: C.lilac }}>¿Lista para el siguiente paso?</p>
              <p style={{ margin: "0 0 15px", fontSize: 13, color: "#a89bc2", lineHeight: 1.75 }}>
                En Feminario te acompañamos a pasar del diagnóstico a la acción — con educación financiera hecha por y para mujeres. Somos más de 60.000 mujeres en todo el continente.
              </p>
              <button onClick={() => setStep(2)} style={{ padding: "10px 20px", borderRadius: 10, background: "transparent", border: `1px solid ${C.plum}`, color: C.lilac, fontFamily: "Montserrat,sans-serif", fontSize: 12, fontWeight: 600, cursor: "pointer" }}>
                ← Ajustar mis números
              </button>
            </div>

            <p style={{ textAlign: "center", fontSize: 10, color: "#3d3050" }}>
              FEMINARIO · En alianza con <span style={{ color: C.davi, fontWeight: 700 }}>DAVIVIENDA</span> · Análisis orientativo, no asesoría financiera profesional.
            </p>
          </div>
        )}
      </div>
    </div>
  );
}
